    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.0",
    "monaco-editor": "^0.55.1",
    "patch-package": "^8.0.1",
    "typescript": "~5.8.3",

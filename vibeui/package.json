    "fuse.js": "^7.1.0",
    "lucide-react": "^0.554.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "y-monaco": "^0.1.6",
    "y-websocket": "^2.0.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",

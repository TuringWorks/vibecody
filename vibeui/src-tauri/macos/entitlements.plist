<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- WebKit JIT (required: VibeUI's webview crashes at startup without this
         under hardened runtime). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Tauri ships dylibs inside the bundle (libwebkit, plugins). Without
         disabling library validation, the loader rejects them under hardened
         runtime. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- VibeUI calls out to model providers (Anthropic / OpenAI / local
         daemons) and may also bind a local port for the daemon. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File picker (Open Folder, file tree) requires read-write access to
         whatever the user picks. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>

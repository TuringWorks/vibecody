{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeCLI",
  "identifier": "com.vibecody.vibeapp",
  "version": "0.4.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "VibeCLI",
        "width": 440,
        "height": 680,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "shadow": true,
        "transparent": false,
        "visible": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "VibeCLI — AI Coding Assistant"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}

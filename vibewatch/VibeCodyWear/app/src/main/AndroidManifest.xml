<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="com.google.android.permission.PROVIDE_BACKGROUND" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@android:style/Theme.DeviceDefault"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true">

        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- W1.2 — Wear OS Tile for the latest job recap. Renders in
             the user's tile carousel; tapping launches MainActivity
             at the recap deep-link. -->
        <service
            android:name=".JobRecapTileService"
            android:label="@string/job_recap_tile_label"
            android:icon="@mipmap/ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/job_recap_tile_preview" />
        </service>

        <!-- G3.6 — Wear OS Tile for the freshest active goal.
             Mirrors the JobRecap tile shape; tapping deep-links into
             the in-app Goals screen. -->
        <service
            android:name=".GoalsTileService"
            android:label="@string/goals_tile_label"
            android:icon="@mipmap/ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
        </service>

        <!-- G5 — Wear OS Tile for the top SkillForge skill. Mirrors the
             Goals tile shape; tapping deep-links into the in-app Skills
             screen. -->
        <service
            android:name=".SkillforgeTileService"
            android:label="@string/skills_tile_label"
            android:icon="@mipmap/ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
        </service>

    </application>

</manifest>

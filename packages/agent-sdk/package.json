{
  "name": "@vibecody/agent-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building custom agents with VibeCLI",
  "author": "Vibe Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TuringWorks/vibecody",
    "directory": "packages/agent-sdk"
  },
  "keywords": ["ai", "agent", "coding-assistant", "vibecli", "llm"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}

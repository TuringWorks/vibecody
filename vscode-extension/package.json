{
  "name": "vibecli",
  "displayName": "VibeCLI",
  "description": "AI-powered coding assistant powered by VibeCLI — multi-provider, open-source",
  "version": "0.1.0",
  "publisher": "vibecody",
  "repository": "https://github.com/TuringWorks/vibecody",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "vibecli.startAgent",     "title": "VibeCLI: Run Agent Task" },
      { "command": "vibecli.chat",           "title": "VibeCLI: Ask Question" },
      { "command": "vibecli.connectDaemon",  "title": "VibeCLI: Connect to Daemon" },
      { "command": "vibecli.startDaemon",    "title": "VibeCLI: Start Daemon" },
      { "command": "vibecli.inlineEdit",     "title": "VibeCLI: Inline Edit (selection)" },
      { "command": "vibecli.viewJobs",       "title": "VibeCLI: View Background Jobs" },
      { "command": "vibecli.sendSelection",  "title": "VibeCLI: Send Selection to Agent" },
      { "command": "vibecli.newGoal",        "title": "VibeCLI: New Goal" },
      { "command": "vibecli.listGoals",      "title": "VibeCLI: List Goals" },
      { "command": "vibecli.startGoal",      "title": "VibeCLI: Start Session on a Goal" },
      { "command": "vibecli.refreshGoals",   "title": "VibeCLI: Refresh Goals",          "icon": "$(refresh)" },
      { "command": "vibecli.goalStartSession", "title": "Start session on this goal",   "icon": "$(play)" },
      { "command": "vibecli.goalShowDetails",  "title": "Show goal details" }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vibecli.refreshGoals",
          "when": "view == vibecli.goalsView",
          "group": "navigation"
        },
        {
          "command": "vibecli.newGoal",
          "when": "view == vibecli.goalsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vibecli.goalStartSession",
          "when": "view == vibecli.goalsView && viewItem == vibecliGoal",
          "group": "inline"
        },
        {
          "command": "vibecli.goalShowDetails",
          "when": "view == vibecli.goalsView && viewItem == vibecliGoal"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vibecli.inlineEdit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      },
      {
        "command": "vibecli.sendSelection",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "VibeCLI",
      "properties": {
        "vibecli.daemonPort": {
          "type": "number",
          "default": 7878,
          "description": "Port that the VibeCLI daemon listens on"
        },
        "vibecli.provider": {
          "type": "string",
          "default": "ollama",
          "enum": [
            "ollama",
            "claude",
            "openai",
            "gemini",
            "grok",
            "groq",
            "mistral",
            "deepseek",
            "cerebras",
            "perplexity",
            "together",
            "fireworks",
            "openrouter",
            "azure_openai",
            "bedrock",
            "copilot",
            "zhipu",
            "minimax",
            "sambanova",
            "vibecli-mistralrs"
          ],
          "description": "AI provider to use. Must be a provider the daemon can build (matches vibe-ai::catalog / create_provider). Set the provider's API key via the app or the daemon; ollama needs no key."
        },
        "vibecli.approval": {
          "type": "string",
          "default": "suggest",
          "enum": ["suggest", "auto-edit", "full-auto"],
          "description": "Approval policy for agent tool calls"
        },
        "vibecli.inlineCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline (ghost text) completions"
        },
        "vibecli.hooks": {
          "type": "array",
          "default": [],
          "description": "Hook chain run on agent events. Same protocol as the CLI / JetBrains plugin: exit 0 = allow, exit 2 = block, structured JSON on stdout overrides.",
          "items": {
            "type": "object",
            "required": ["name", "event", "command"],
            "properties": {
              "name":    { "type": "string", "description": "Display name for logs and errors." },
              "event":   { "type": "string", "enum": ["PreToolUse", "PostToolUse", "UserPromptSubmit", "Stop", "SubagentStop", "Notification", "PreCompact"] },
              "command": { "type": "string", "description": "Shell command to run. Event payload is piped on stdin as JSON." },
              "enabled": { "type": "boolean", "default": true }
            }
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibecli-sidebar",
          "title": "VibeCLI",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "vibecli-sidebar": [
        {
          "type": "webview",
          "id": "vibecli.chatView",
          "name": "Chat"
        },
        {
          "id": "vibecli.goalsView",
          "name": "Goals"
        }
      ]
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "typescript": "^5.3.0"
  }
}
